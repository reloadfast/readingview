# ReadingView — Bootstrap Environment Variables
# Copy this file to .env and fill in your values.
# All other configuration (ABS credentials, notifications, etc.) is managed
# through the Settings UI after the container starts.

# Required: SQLite database path (mounted volume)
DATABASE_URL=sqlite+aiosqlite:////data/readingview.db

# Required: Secret key for session signing (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# Optional: Container port (default: 8000)
PORT=8000

# Optional: Timezone
TZ=UTC
