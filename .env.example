# ReadingView — Bootstrap Environment Variables
# Copy this file to .env and fill in your values.
# All other configuration (ABS credentials, notifications, etc.) is managed
# through the Settings UI after the container starts.

# Required: SQLite database path (mounted volume)
DATABASE_URL=sqlite+aiosqlite:////data/readingview.db

# Required: Secret key for session signing (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# Optional: Container port (default: 8000)
PORT=8000

# Optional: Timezone
TZ=UTC

# Optional: Bearer token to protect /api/backup and /api/restore (recommended)
# When set, requests must include: Authorization: Bearer <token>
# Leave unset to allow unauthenticated access (not recommended on exposed ports)
BACKUP_TOKEN=

# Optional: Maximum upload size for /api/restore in bytes (default: 1 GiB)
BACKUP_MAX_RESTORE_BYTES=1073741824

# Optional: Log level (default: INFO). One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Log format (default: text). Use "json" for structured JSON logs (useful in log aggregators)
LOG_FORMAT=text
